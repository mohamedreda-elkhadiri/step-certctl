#!/bin/bash
set -euo pipefail

VERSION="0.1.1"
SCRIPT_NAME="step-certctl"
CONFIG_DIR="${CONFIG_DIR:-/etc/step-certctl}"
LIB_DIR="${LIB_DIR:-/usr/lib/step-certctl}"

# Source shared functions if available
if [ -f "${LIB_DIR}/functions.sh" ]; then
    source "${LIB_DIR}/functions.sh"
elif [ -f "$(dirname "$0")/../lib/step-certctl-functions.sh" ]; then
    # Development mode - source from relative path
    source "$(dirname "$0")/../lib/step-certctl-functions.sh"
fi

# Color output for terminals
if [ -t 1 ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    NC='\033[0m'
else
    RED=''
    GREEN=''
    YELLOW=''
    BLUE=''
    NC=''
fi

log_info() {
    echo -e "${BLUE}[INFO]${NC} $*"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $*"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $*"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $*" >&2
}

usage() {
    cat <<EOF
${SCRIPT_NAME} - Generic certificate management for Smallstep CA

Usage: ${SCRIPT_NAME} <command> <name> [options]

Commands:
    issue <name>         Issue a new certificate using config
    renew <name>         Renew an existing certificate
    validate <name>      Validate certificate and configuration
    install-timer <name> Install and enable systemd timer for renewal
    remove-timer <name>  Disable and remove systemd timer
    list                 List all configured certificates
    version              Show version information

Configuration:
    Configs are read from ${CONFIG_DIR}/<name>.conf

Examples:
    ${SCRIPT_NAME} issue pveproxy
    ${SCRIPT_NAME} renew pveproxy
    ${SCRIPT_NAME} validate pveproxy
    ${SCRIPT_NAME} install-timer pveproxy
    ${SCRIPT_NAME} list

Version: ${VERSION}
EOF
}

load_config() {
    local name="$1"
    local config_file="${CONFIG_DIR}/${name}.conf"

    if [ ! -f "${config_file}" ]; then
        log_error "Config file not found: ${config_file}"
        exit 1
    fi

    # Source the config file
    # shellcheck disable=SC1090
    source "${config_file}"

    # Validate required variables
    local required_vars=(
        "CERT_FILE"
        "KEY_FILE"
        "CA_URL"
        "ROOT_CA"
        "COMMON_NAME"
    )

    for var in "${required_vars[@]}"; do
        if [ -z "${!var:-}" ]; then
            log_error "Required variable ${var} not set in ${config_file}"
            exit 1
        fi
    done

    # Set defaults for optional variables
    # EXPIRES_IN accepts hours (e.g. 8h, 24h) or days (e.g. 4d, 7d).
    # Days are converted to hours because the step CLI only supports h/m/s suffixes.
    EXPIRES_IN="${EXPIRES_IN:-8h}"
    if [[ "${EXPIRES_IN}" =~ ^([0-9]+)d$ ]]; then
        EXPIRES_IN="$(( ${BASH_REMATCH[1]} * 24 ))h"
    fi
    RELOAD_CMD="${RELOAD_CMD:-}"
    OWNER="${OWNER:-root}"
    GROUP="${GROUP:-root}"
    CERT_MODE="${CERT_MODE:-0644}"
    KEY_MODE="${KEY_MODE:-0600}"
    SAN="${SAN:-${COMMON_NAME}}"
    PROVISIONER="${PROVISIONER:-}"
    PROVISIONER_PASSWORD_FILE="${PROVISIONER_PASSWORD_FILE:-}"
    CERT_TEMPLATE="${CERT_TEMPLATE:-}"
}

get_pubkey_from_cert() {
    local cert_file="$1"

    if [ ! -f "${cert_file}" ]; then
        return 1
    fi

    openssl x509 -in "${cert_file}" -noout -pubkey 2>/dev/null || return 1
}

certs_are_different() {
    local old_cert="$1"
    local new_cert="$2"

    if [ ! -f "${old_cert}" ]; then
        return 0  # No old cert, they're different
    fi

    local old_pubkey
    local new_pubkey

    old_pubkey=$(get_pubkey_from_cert "${old_cert}")
    new_pubkey=$(get_pubkey_from_cert "${new_cert}")

    if [ "${old_pubkey}" != "${new_pubkey}" ]; then
        return 0  # Different
    else
        return 1  # Same
    fi
}

cmd_issue() {
    local name="$1"
    load_config "${name}"

    log_info "Issuing certificate for ${COMMON_NAME}"
    log_info "Config: ${CONFIG_DIR}/${name}.conf"

    # Create directories if they don't exist
    local cert_dir
    cert_dir=$(dirname "${CERT_FILE}")
    local key_dir
    key_dir=$(dirname "${KEY_FILE}")

    mkdir -p "${cert_dir}" "${key_dir}"

    # Build step command
    local step_cmd=(
        step ca certificate
        "${COMMON_NAME}"
        "${CERT_FILE}"
        "${KEY_FILE}"
        --ca-url="${CA_URL}"
        --root="${ROOT_CA}"
        --san="${SAN}"
        --not-after="${EXPIRES_IN}"
        --force
    )

    [[ -n "${PROVISIONER}" ]] && step_cmd+=(--provisioner="${PROVISIONER}")
    [[ -n "${PROVISIONER_PASSWORD_FILE}" ]] && step_cmd+=(--provisioner-password-file="${PROVISIONER_PASSWORD_FILE}")
    [[ -n "${CERT_TEMPLATE}" ]] && step_cmd+=(--set-file="${CERT_TEMPLATE}")

    log_info "Running: ${step_cmd[*]}"

    if "${step_cmd[@]}"; then
        log_success "Certificate issued successfully"

        # Set ownership and permissions
        chown "${OWNER}:${GROUP}" "${CERT_FILE}"
        chown "${OWNER}:${GROUP}" "${KEY_FILE}"
        chmod "${CERT_MODE}" "${CERT_FILE}"
        chmod "${KEY_MODE}" "${KEY_FILE}"

        log_info "Set ownership to ${OWNER}:${GROUP}"
        log_info "Set permissions: cert=${CERT_MODE}, key=${KEY_MODE}"

        # Run reload command if specified
        if [ -n "${RELOAD_CMD}" ]; then
            log_info "Running reload command: ${RELOAD_CMD}"
            if eval "${RELOAD_CMD}"; then
                log_success "Reload command executed successfully"
            else
                log_warn "Reload command failed"
            fi
        fi

        return 0
    else
        log_error "Failed to issue certificate"
        return 1
    fi
}

cmd_renew() {
    local name="$1"
    load_config "${name}"

    log_info "Renewing certificate for ${COMMON_NAME}"

    # Create temp file for new cert
    local temp_cert
    temp_cert=$(mktemp)
    local temp_key
    temp_key=$(mktemp)

    # Ensure cleanup
    trap 'rm -f "${temp_cert:-}" "${temp_key:-}"' EXIT

    # Renew certificate to temp location
    local step_cmd=(
        step ca renew
        "${CERT_FILE}"
        "${KEY_FILE}"
        --ca-url="${CA_URL}"
        --root="${ROOT_CA}"
        --expires-in="${EXPIRES_IN}"
        --out="${temp_cert}"
        --key="${temp_key}"
        --force
    )

    log_info "Running: ${step_cmd[*]}"

    if ! "${step_cmd[@]}"; then
        log_error "Failed to renew certificate"
        rm -f "${temp_cert}" "${temp_key}"
        return 1
    fi

    # Check if certificate actually changed
    if certs_are_different "${CERT_FILE}" "${temp_cert}"; then
        log_info "Certificate has changed, updating"

        # Backup old cert
        if [ -f "${CERT_FILE}" ]; then
            cp "${CERT_FILE}" "${CERT_FILE}.bak"
            cp "${KEY_FILE}" "${KEY_FILE}.bak"
            log_info "Backed up old certificate"
        fi

        # Move new cert into place
        mv "${temp_cert}" "${CERT_FILE}"
        mv "${temp_key}" "${KEY_FILE}"

        # Set ownership and permissions
        chown "${OWNER}:${GROUP}" "${CERT_FILE}"
        chown "${OWNER}:${GROUP}" "${KEY_FILE}"
        chmod "${CERT_MODE}" "${CERT_FILE}"
        chmod "${KEY_MODE}" "${KEY_FILE}"

        log_success "Certificate renewed successfully"

        # Run reload command
        if [ -n "${RELOAD_CMD}" ]; then
            log_info "Running reload command: ${RELOAD_CMD}"
            if eval "${RELOAD_CMD}"; then
                log_success "Service reloaded successfully"
            else
                log_warn "Reload command failed"
            fi
        fi
    else
        log_info "Certificate unchanged, skipping reload"
        rm -f "${temp_cert}" "${temp_key}"
    fi

    return 0
}

cmd_validate() {
    local name="$1"
    load_config "${name}"

    log_info "Validating configuration and certificate for ${name}"

    # Check config file exists
    if [ -f "${CONFIG_DIR}/${name}.conf" ]; then
        log_success "Config file exists: ${CONFIG_DIR}/${name}.conf"
    else
        log_error "Config file not found"
        return 1
    fi

    # Check certificate exists
    if [ -f "${CERT_FILE}" ]; then
        log_success "Certificate exists: ${CERT_FILE}"

        # Check certificate validity
        if openssl x509 -in "${CERT_FILE}" -noout -checkend 0 2>/dev/null; then
            local expiry
            expiry=$(openssl x509 -in "${CERT_FILE}" -noout -enddate | cut -d= -f2)
            log_success "Certificate is valid until: ${expiry}"
        else
            log_error "Certificate has expired"
            return 1
        fi
    else
        log_warn "Certificate not found: ${CERT_FILE}"
    fi

    # Check key exists
    if [ -f "${KEY_FILE}" ]; then
        log_success "Key exists: ${KEY_FILE}"
    else
        log_warn "Key not found: ${KEY_FILE}"
    fi

    # Check root CA
    if [ -f "${ROOT_CA}" ]; then
        log_success "Root CA exists: ${ROOT_CA}"
    else
        log_error "Root CA not found: ${ROOT_CA}"
        return 1
    fi

    # Check CA connectivity
    if curl -sf --cacert "${ROOT_CA}" "${CA_URL}/health" >/dev/null 2>&1; then
        log_success "CA is reachable: ${CA_URL}"
    else
        log_warn "CA health check failed (this may be normal)"
    fi

    # Check permissions
    local actual_cert_perms
    local actual_key_perms
    actual_cert_perms=$(stat -c "%a" "${CERT_FILE}" 2>/dev/null || echo "N/A")
    actual_key_perms=$(stat -c "%a" "${KEY_FILE}" 2>/dev/null || echo "N/A")

    log_info "Certificate permissions: ${actual_cert_perms} (expected: ${CERT_MODE})"
    log_info "Key permissions: ${actual_key_perms} (expected: ${KEY_MODE})"

    log_success "Validation complete"
    return 0
}

cmd_install_timer() {
    local name="$1"

    # Verify config exists
    if [ ! -f "${CONFIG_DIR}/${name}.conf" ]; then
        log_error "Config file not found: ${CONFIG_DIR}/${name}.conf"
        log_error "Create the config file before installing the timer"
        return 1
    fi

    log_info "Installing systemd timer for ${name}"

    # Enable and start timer
    if systemctl enable "step-certctl@${name}.timer"; then
        log_success "Timer enabled: step-certctl@${name}.timer"
    else
        log_error "Failed to enable timer"
        return 1
    fi

    if systemctl start "step-certctl@${name}.timer"; then
        log_success "Timer started: step-certctl@${name}.timer"
    else
        log_error "Failed to start timer"
        return 1
    fi

    # Show timer status
    log_info "Timer status:"
    systemctl status "step-certctl@${name}.timer" --no-pager || true

    log_info "Next run:"
    systemctl list-timers "step-certctl@${name}.timer" --no-pager || true

    return 0
}

cmd_remove_timer() {
    local name="$1"

    log_info "Removing systemd timer for ${name}"

    # Stop and disable timer
    if systemctl stop "step-certctl@${name}.timer" 2>/dev/null; then
        log_success "Timer stopped"
    fi

    if systemctl disable "step-certctl@${name}.timer" 2>/dev/null; then
        log_success "Timer disabled"
    fi

    log_success "Timer removed: step-certctl@${name}.timer"
    return 0
}

cmd_list() {
    log_info "Configured certificates in ${CONFIG_DIR}:"
    echo

    if [ ! -d "${CONFIG_DIR}" ]; then
        log_warn "Config directory does not exist: ${CONFIG_DIR}"
        return 0
    fi

    local found=0
    for conf in "${CONFIG_DIR}"/*.conf; do
        if [ -f "${conf}" ]; then
            found=1
            local name
            name=$(basename "${conf}" .conf)

            # Load config to get details
            # shellcheck disable=SC1090
            source "${conf}"

            echo "  ${name}"
            echo "    Common Name: ${COMMON_NAME:-N/A}"
            echo "    Certificate: ${CERT_FILE:-N/A}"
            echo "    Key: ${KEY_FILE:-N/A}"

            # Check if timer is active
            if systemctl is-enabled "step-certctl@${name}.timer" >/dev/null 2>&1; then
                echo "    Timer: enabled"
            else
                echo "    Timer: disabled"
            fi

            # Check cert validity
            if [ -f "${CERT_FILE}" ]; then
                if openssl x509 -in "${CERT_FILE}" -noout -checkend 0 2>/dev/null; then
                    local expiry
                    expiry=$(openssl x509 -in "${CERT_FILE}" -noout -enddate | cut -d= -f2)
                    echo "    Status: valid until ${expiry}"
                else
                    echo "    Status: EXPIRED"
                fi
            else
                echo "    Status: not issued"
            fi

            echo
        fi
    done

    if [ ${found} -eq 0 ]; then
        log_info "No certificates configured"
    fi

    return 0
}

cmd_version() {
    echo "${SCRIPT_NAME} version ${VERSION}"
    echo
    echo "Dependencies:"
    if command -v step >/dev/null 2>&1; then
        echo "  step-cli: $(step version | head -n1)"
    else
        echo "  step-cli: NOT FOUND"
    fi

    if command -v systemctl >/dev/null 2>&1; then
        echo "  systemd: $(systemctl --version | head -n1)"
    else
        echo "  systemd: NOT FOUND"
    fi
}

main() {
    if [ $# -eq 0 ]; then
        usage
        exit 1
    fi

    local command="$1"
    shift

    case "${command}" in
        issue)
            if [ $# -lt 1 ]; then
                log_error "Usage: ${SCRIPT_NAME} issue <name>"
                exit 1
            fi
            cmd_issue "$1"
            ;;
        renew)
            if [ $# -lt 1 ]; then
                log_error "Usage: ${SCRIPT_NAME} renew <name>"
                exit 1
            fi
            cmd_renew "$1"
            ;;
        validate)
            if [ $# -lt 1 ]; then
                log_error "Usage: ${SCRIPT_NAME} validate <name>"
                exit 1
            fi
            cmd_validate "$1"
            ;;
        install-timer)
            if [ $# -lt 1 ]; then
                log_error "Usage: ${SCRIPT_NAME} install-timer <name>"
                exit 1
            fi
            cmd_install_timer "$1"
            ;;
        remove-timer)
            if [ $# -lt 1 ]; then
                log_error "Usage: ${SCRIPT_NAME} remove-timer <name>"
                exit 1
            fi
            cmd_remove_timer "$1"
            ;;
        list)
            cmd_list
            ;;
        version)
            cmd_version
            ;;
        -h|--help|help)
            usage
            exit 0
            ;;
        *)
            log_error "Unknown command: ${command}"
            echo
            usage
            exit 1
            ;;
    esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
